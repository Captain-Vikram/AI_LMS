# Core backend
MONGO_URI=mongodb://localhost:27017/quasar
REDIS_URL=redis://localhost:6379/0
# or if running in docker: REDIS_URL=redis://quasar-redis:6379/0

# Clerk Auth
# Required for token verification in Backend/functions/utils.py
CLERK_JWKS_URL=https://<your-clerk-frontend-api>/.well-known/jwks.json

# Legacy Auth (deprecated)
SECRET_KEY=replace-with-strong-secret
JWT_ALGORITHM=HS256

# Existing LM Studio usage in backend
LMSTUDIO_URL=http://127.0.0.1:1234
LMSTUDIO_MODEL=auto
LMSTUDIO_API_KEY=

# Portable RAG storage (SQLite + Chroma)
PORTABLE_DATA_DIR=./data/portable_rag

# Optional external vector DB/API endpoint (kept separate from backend :8000)
VECTOR_DB_API_BASE_URL=http://127.0.0.1:18001

# Retrieval / chunking
DEFAULT_CHUNK_SIZE=1200
DEFAULT_CHUNK_OVERLAP=180
DEFAULT_RETRIEVAL_K=6
CHAT_HISTORY_WINDOW=8
MAX_SOURCE_CHARACTERS=1000000
MAX_UPLOAD_MB=50
ALLOWED_UPLOAD_EXTENSIONS_CSV=.txt,.md,.csv,.json,.pdf,.docx,.html,.xml,.py,.js,.ts,.mp3,.wav,.m4a,.mp4,.mov,.mkv

# Provider defaults
DEFAULT_CHAT_PROVIDER=local
# Valid values: local | gemini | lmstudio
DEFAULT_EMBEDDING_PROVIDER=local

# Local provider (Ollama)
LOCAL_LLM_BASE_URL=http://localhost:11434
LOCAL_LLM_MODEL=llama3.1:8b
LOCAL_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# LM Studio OpenAI-compatible endpoint for portable RAG
LMSTUDIO_BASE_URL=http://localhost:1234/v1
LMSTUDIO_CHAT_MODEL=auto
LMSTUDIO_EMBEDDING_MODEL=auto

# Gemini (optional)
GOOGLE_API_KEY=
GEMINI_CHAT_MODEL=gemini-1.5-flash
GEMINI_EMBEDDING_MODEL=text-embedding-004

# Optional remote podcast forwarding target for portable RAG podcast routes
# Example: http://localhost:5055/api
REMOTE_API_BASE_URL=

# Speech
# STT provider selection: whisper | deepgram | auto
STT_PROVIDER=auto
DEEPGRAM_API_KEY=
DEEPGRAM_STT_MODEL=nova-3
DEEPGRAM_BASE_URL=https://api.deepgram.com/v1
WHISPER_MODEL_SIZE=base
TTS_LANGUAGE=en

# Portable jobs
JOB_WORKER_COUNT=2
