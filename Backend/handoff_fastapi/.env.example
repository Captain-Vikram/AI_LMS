# Portable RAG backend settings

# Storage paths
PORTABLE_DATA_DIR=./data/portable_rag

# Optional external vector DB/API endpoint (host port should not collide with backend :8000)
VECTOR_DB_API_BASE_URL=http://127.0.0.1:18001

# Chunking and retrieval
DEFAULT_CHUNK_SIZE=1200
DEFAULT_CHUNK_OVERLAP=180
DEFAULT_RETRIEVAL_K=6
CHAT_HISTORY_WINDOW=8
MAX_SOURCE_CHARACTERS=1000000
MAX_UPLOAD_MB=50
ALLOWED_UPLOAD_EXTENSIONS_CSV=.txt,.md,.csv,.json,.pdf,.docx,.html,.xml,.py,.js,.ts,.mp3,.wav,.m4a,.mp4,.mov,.mkv

# Model provider selection: local, lmstudio, or gemini
DEFAULT_CHAT_PROVIDER=local
DEFAULT_EMBEDDING_PROVIDER=local

# Local model setup (Ollama)
LOCAL_LLM_BASE_URL=http://localhost:11434
LOCAL_LLM_MODEL=llama3.1:8b
LOCAL_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# LM Studio setup (OpenAI-compatible API)
# Keep /v1 suffix for OpenAI-compatible endpoints.
LMSTUDIO_BASE_URL=http://localhost:1234/v1
# Optional when LM Studio auth is enabled. Leave empty for local LM Studio without auth.
LMSTUDIO_API_KEY=
# Use auto to detect loaded models from /v1/models.
LMSTUDIO_CHAT_MODEL=auto
LMSTUDIO_EMBEDDING_MODEL=auto

# Gemini setup
GOOGLE_API_KEY=
GEMINI_CHAT_MODEL=gemini-1.5-flash
GEMINI_EMBEDDING_MODEL=text-embedding-004

# Speech setup
# STT provider selection: whisper | deepgram | auto
STT_PROVIDER=auto
DEEPGRAM_API_KEY=
DEEPGRAM_STT_MODEL=nova-3
DEEPGRAM_BASE_URL=https://api.deepgram.com/v1
WHISPER_MODEL_SIZE=base
TTS_LANGUAGE=en

# Default fallback system prompt (used when no custom chat_system prompt template exists)
DEFAULT_CHAT_SYSTEM_PROMPT=You are a strictly grounded retrieval assistant. Use only information from the provided Context block. Every factual statement must include one or more inline citations using [n] where n matches a Context citation index. Do not invent facts. Do not invent citations. If context is insufficient, explicitly say what is missing.

# Background jobs
JOB_WORKER_COUNT=2
