# Example .env file — DO NOT commit real secrets here.
# Copy to `.env` and fill with real values locally.

# API keys
GOOGLE_API_KEY=
DEEPGRAM_API_KEY=
TAVILY_API_KEY=
GROQ_API_KEY=
SERPER_API_KEY=
LMSTUDIO_API_KEY=
LMSTUDIO_API_TOKEN=

# App secrets
SECRET_KEY=change-me-please
ACCESS_TOKEN_EXPIRE_MINUTES=43200

# Database
MONGODB_URI=mongodb://localhost:27017/your-db

# Optional dev/test toggles
DEBUG=true

# Other provider keys (placeholders)
# Example: STRIPE_API_KEY=, SENDGRID_API_KEY=, S3_BUCKET=, AWS_ACCESS_KEY_ID=, AWS_SECRET_ACCESS_KEY=
